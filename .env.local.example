# Drizzle DB connection (server-side only)
# Supabase Dashboard → Project Settings → Database → Connection string → URI (Direct, 5432)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres

# (선택) v0.4 호환 — v0.5 코드에서는 사용 안 함. 보유만 OK.
# DIRECT_DATABASE_URL=

# Supabase Auth — public (클라이언트 노출 OK)
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
# Supabase 신 명칭 (2025+) — 새 프로젝트 권장.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-me
# 구 명칭 fallback. 둘 중 하나만 있으면 됨.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# (선택) v0.5는 service_role 사용 안 함. 다음 사이클 admin 호출 시 추가.
# SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API v3 (server-side only — videos.list 단일 호출 경로)
YOUTUBE_API_KEY=replace-me

# Gemini API — v0.5 스코프 OOS (stub만, 실호출은 다음 사이클).
# 값은 placeholder. ./src/lib/ingestion/llm-stub.ts가 throw 처리하므로 사용되지 않음.
GEMINI_API_KEY=stub
