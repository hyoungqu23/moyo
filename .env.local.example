NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# YouTube Data API v3 (server-side only — videos.list 단일 호출 경로)
YOUTUBE_API_KEY=replace-me

# Gemini API — v0.5 스코프 OOS (stub만, 실호출은 다음 사이클).
